# ─── DATABASE (Supabase Postgres) ───────────────────────────────────────────
DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=your-supabase-host.supabase.co
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=postgres
DB_POSTGRESDB_USER=postgres
DB_POSTGRESDB_PASSWORD=your-supabase-password
DB_POSTGRESDB_SSL_ENABLED=true

# ─── N8N CORE ────────────────────────────────────────────────────────────────
N8N_ENCRYPTION_KEY=replace-with-any-random-string-eg-ama2026secret
N8N_HOST=0.0.0.0
N8N_PORT=5678
NODE_ENV=production

# ─── WEBHOOK ─────────────────────────────────────────────────────────────────
# Replace with your actual Render service URL after deployment
WEBHOOK_URL=https://your-service-name.onrender.com

# ─── OPTIONAL: Basic Auth to protect your n8n dashboard ─────────────────────
# N8N_BASIC_AUTH_ACTIVE=true
# N8N_BASIC_AUTH_USER=admin
# N8N_BASIC_AUTH_PASSWORD=yourpassword
